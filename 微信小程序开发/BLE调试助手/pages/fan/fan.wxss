page {
  min-height: 100%;
  background: #eef2f0;
}

.fan-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 8% 18%, rgba(252, 112, 82, 0.16) 0, rgba(252, 112, 82, 0) 210rpx),
    radial-gradient(circle at 92% 10%, rgba(126, 40, 236, 0.16) 0, rgba(126, 40, 236, 0) 230rpx),
    linear-gradient(145deg, #f8faf8 0%, #e4ecea 58%, #d7dddb 100%);
}

.connection-panel,
.control-section,
.telemetry,
.log-list {
  position: relative;
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(234, 239, 237, 0.88));
  box-shadow:
    18rpx 22rpx 44rpx rgba(43, 57, 53, 0.16),
    -12rpx -14rpx 30rpx rgba(255, 255, 255, 0.86),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.96);
}

.connection-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
}

.status-block {
  flex: 1;
  min-width: 0;
}

.status-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #101c1a;
}

.status-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #6c7d79;
}

.small-btn {
  min-width: 132rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #0ca78c, #087a68);
  color: #fff;
  font-size: 25rpx;
  font-weight: 700;
  margin: 0;
  flex-shrink: 0;
  box-shadow: 0 14rpx 24rpx rgba(8, 122, 104, 0.26);
}

.small-btn.ghost {
  margin-left: auto;
  background: linear-gradient(145deg, #ffffff, #dde5e2);
  color: #2f4641;
  box-shadow:
    8rpx 10rpx 20rpx rgba(39, 54, 50, 0.14),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.9);
}

.device-list {
  max-height: 70vh;
}

.device-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 28rpx rgba(35, 48, 45, 0.12);
}

.device-name,
.device-id,
.device-rssi {
  display: block;
}

.device-name {
  font-size: 29rpx;
  font-weight: 800;
  color: #203a35;
}

.device-id,
.device-rssi,
.empty-device {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7d8d8a;
}

.empty-device {
  padding: 100rpx 20rpx;
  text-align: center;
}

.metric-grid {
  margin-bottom: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.metric-card {
  position: relative;
  overflow: hidden;
  min-height: 142rpx;
  padding: 22rpx 16rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #ffffff, #dfe8e5);
  color: #101c1a;
  box-shadow:
    12rpx 16rpx 32rpx rgba(44, 59, 55, 0.14),
    -8rpx -8rpx 20rpx rgba(255, 255, 255, 0.86);
  box-sizing: border-box;
}

.metric-card:nth-child(1) {
  background: linear-gradient(145deg, #fff7f3, #ffd6ca);
}

.metric-card:nth-child(2) {
  background: linear-gradient(145deg, #f6f2ff, #d9c4ff);
}

.metric-card:nth-child(3) {
  background: linear-gradient(145deg, #effffb, #bfeee2);
}

.metric-label {
  display: block;
  font-size: 22rpx;
  color: rgba(16, 28, 26, 0.56);
}

.metric-value {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 900;
  color: #0e1b18;
}

.metric-unit {
  margin-left: 3rpx;
  font-size: 22rpx;
}

.fan-stage {
  position: relative;
  min-height: 510rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
  border-radius: 44rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(213, 221, 219, 0.88)),
    linear-gradient(145deg, #f8fbfa, #d5dcda);
  box-shadow:
    22rpx 28rpx 58rpx rgba(28, 39, 36, 0.22),
    -14rpx -16rpx 36rpx rgba(255, 255, 255, 0.9),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.fan-stage::after {
  content: "";
  position: absolute;
  left: 90rpx;
  right: 90rpx;
  bottom: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(34, 45, 42, 0.16);
  box-shadow: 0 0 30rpx rgba(34, 45, 42, 0.12);
}

.stage-glow {
  position: absolute;
  width: 360rpx;
  height: 360rpx;
  left: -80rpx;
  top: 40rpx;
  border-radius: 50%;
  background: rgba(255, 112, 82, 0.2);
}

.stage-on .stage-glow {
  background: rgba(12, 167, 140, 0.2);
}

.fan-machine {
  position: absolute;
  left: 38rpx;
  top: 50rpx;
  width: 390rpx;
  height: 420rpx;
  transform: rotateX(6deg) rotateY(-12deg);
  transform-origin: center bottom;
}

.fan-head {
  position: absolute;
  left: 48rpx;
  top: 0;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #fefefe, #cdd8d5);
  box-shadow:
    22rpx 24rpx 42rpx rgba(21, 31, 28, 0.28),
    inset -14rpx -14rpx 24rpx rgba(55, 70, 66, 0.14),
    inset 14rpx 12rpx 22rpx rgba(255, 255, 255, 0.94);
}

.fan-back-ring,
.fan-front-ring {
  position: absolute;
  inset: 18rpx;
  border-radius: 50%;
  border: 12rpx solid rgba(25, 38, 35, 0.12);
}

.fan-front-ring {
  inset: 34rpx;
  border-width: 4rpx;
  border-color: rgba(17, 31, 28, 0.2);
  z-index: 8;
}

.fan-cage {
  position: absolute;
  inset: 36rpx;
  z-index: 7;
  border-radius: 50%;
}

.cage-line {
  position: absolute;
  left: 50%;
  top: 6rpx;
  width: 3rpx;
  height: 218rpx;
  border-radius: 999rpx;
  background: rgba(23, 42, 38, 0.18);
  transform-origin: 50% 108rpx;
}

.line-1 {
  transform: translateX(-50%) rotate(0deg);
}

.line-2 {
  transform: translateX(-50%) rotate(45deg);
}

.line-3 {
  transform: translateX(-50%) rotate(90deg);
}

.line-4 {
  transform: translateX(-50%) rotate(135deg);
}

.fan-rotor {
  position: absolute;
  left: 71rpx;
  top: 71rpx;
  width: 158rpx;
  height: 158rpx;
  z-index: 5;
  border-radius: 50%;
  transform-origin: center center;
}

.fan-blade {
  position: absolute;
  left: 72rpx;
  top: 8rpx;
  width: 42rpx;
  height: 96rpx;
  border-radius: 42rpx 42rpx 18rpx 18rpx;
  background: linear-gradient(165deg, #15211f, #0aa389 72%, #a9fff0);
  box-shadow: 8rpx 10rpx 18rpx rgba(14, 28, 25, 0.22);
  transform-origin: 7rpx 72rpx;
}

.blade-1 {
  transform: rotate(0deg);
}

.blade-2 {
  transform: rotate(120deg);
}

.blade-3 {
  transform: rotate(240deg);
}

.fan-hub {
  position: absolute;
  left: 122rpx;
  top: 122rpx;
  width: 56rpx;
  height: 56rpx;
  z-index: 9;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #ffffff 0, #dfe8e5 35%, #162521 72%);
  box-shadow: 0 10rpx 16rpx rgba(13, 28, 25, 0.24);
}

.fan-neck {
  position: absolute;
  left: 183rpx;
  top: 284rpx;
  width: 34rpx;
  height: 82rpx;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #cdd8d5, #ffffff 45%, #aebab5);
  box-shadow: 10rpx 10rpx 20rpx rgba(22, 34, 31, 0.18);
}

.fan-stand {
  position: absolute;
  left: 196rpx;
  top: 340rpx;
  width: 8rpx;
  height: 56rpx;
  border-radius: 10rpx;
  background: #172420;
}

.fan-base {
  position: absolute;
  left: 86rpx;
  bottom: 0;
  width: 230rpx;
  height: 58rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #fefefe, #b9c6c2);
  box-shadow:
    16rpx 18rpx 28rpx rgba(20, 31, 28, 0.2),
    inset 8rpx 10rpx 18rpx rgba(255, 255, 255, 0.9);
}

.base-light {
  position: absolute;
  left: 80rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff7052;
  box-shadow: 0 0 22rpx rgba(255, 112, 82, 0.8);
}

.stage-on .base-light {
  background: #0ca78c;
  box-shadow: 0 0 26rpx rgba(12, 167, 140, 0.9);
}

.fan-stage-info {
  position: absolute;
  right: 30rpx;
  top: 82rpx;
  width: 230rpx;
  min-height: 218rpx;
  padding: 28rpx;
  box-sizing: border-box;
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(231, 237, 235, 0.92));
  box-shadow:
    18rpx 22rpx 40rpx rgba(29, 42, 38, 0.18),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.98);
}

.stage-label {
  display: block;
  font-size: 23rpx;
  color: #74817e;
}

.stage-value {
  display: block;
  margin-top: 10rpx;
  font-size: 60rpx;
  line-height: 1;
  font-weight: 900;
  color: #101c1a;
}

.speed-meter {
  margin-top: 28rpx;
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  height: 58rpx;
}

.meter-dot {
  width: 24rpx;
  border-radius: 14rpx;
  background: #cfd8d5;
  box-shadow: inset 2rpx 2rpx 5rpx rgba(40, 52, 49, 0.16);
}

.meter-dot:nth-child(1) {
  height: 22rpx;
}

.meter-dot:nth-child(2) {
  height: 30rpx;
}

.meter-dot:nth-child(3) {
  height: 38rpx;
}

.meter-dot:nth-child(4) {
  height: 48rpx;
}

.meter-dot:nth-child(5) {
  height: 58rpx;
}

.meter-dot.on {
  background: linear-gradient(180deg, #0fd8b5, #087a68);
  box-shadow: 0 8rpx 16rpx rgba(12, 167, 140, 0.24);
}

.fan-off {
  animation: none;
}

.fan-speed-1 {
  animation: fanSpin 1.1s linear infinite;
}

.fan-speed-2 {
  animation: fanSpin 0.82s linear infinite;
}

.fan-speed-3 {
  animation: fanSpin 0.58s linear infinite;
}

.fan-speed-4 {
  animation: fanSpin 0.38s linear infinite;
}

.fan-speed-5 {
  animation: fanSpin 0.24s linear infinite;
}

@keyframes fanSpin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.section-head {
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #162622;
}

.section-extra {
  font-size: 23rpx;
  color: #7b8b87;
}

.power-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  background: linear-gradient(145deg, #ffffff, #dbe4e1);
  color: #2b4640;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow:
    12rpx 14rpx 26rpx rgba(37, 51, 47, 0.14),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.96);
}

.power-btn.on {
  background: linear-gradient(145deg, #12c9aa, #087a68);
  color: #fff;
  box-shadow: 0 16rpx 28rpx rgba(12, 167, 140, 0.28);
}

.scene-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.scene-card {
  min-height: 188rpx;
  padding: 20rpx 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #ffffff, #dfe8e5);
  box-shadow:
    12rpx 14rpx 26rpx rgba(37, 51, 47, 0.13),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.scene-card.active {
  background: linear-gradient(145deg, #162622, #2d3e39);
  box-shadow: 0 16rpx 28rpx rgba(24, 39, 35, 0.2);
}

.scene-card.busy {
  opacity: 0.76;
}

.scene-name {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  color: #162622;
}

.scene-detail {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6b7c78;
}

.scene-tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(17, 28, 26, 0.08);
  font-size: 20rpx;
  color: #415651;
}

.scene-card.active .scene-name,
.scene-card.active .scene-detail,
.scene-card.active .scene-tag {
  color: #f2fbf8;
}

.scene-card.active .scene-tag {
  background: rgba(255, 255, 255, 0.12);
}

.timer-section {
  overflow: hidden;
}

.timer-status {
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(235, 242, 239, 0.9);
  box-shadow: inset 6rpx 8rpx 16rpx rgba(45, 60, 56, 0.08);
}

.timer-status.active {
  background: linear-gradient(145deg, #162622, #2b3d38);
  box-shadow: 0 14rpx 26rpx rgba(24, 39, 35, 0.18);
}

.timer-status-label {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #6b7c78;
}

.timer-status.active .timer-status-label {
  color: #e9fffa;
}

.timer-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.timer-card {
  min-height: 250rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #ffffff, #dfe8e5);
  box-shadow:
    12rpx 14rpx 26rpx rgba(37, 51, 47, 0.13),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
}

.timer-card.active {
  background: linear-gradient(145deg, #f0fffb, #bdeee2);
  box-shadow:
    12rpx 16rpx 30rpx rgba(12, 167, 140, 0.16),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.96);
}

.timer-label {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
  color: #162622;
}

.timer-input-row,
.time-picker {
  height: 78rpx;
  margin-top: 18rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: rgba(243, 248, 246, 0.92);
  box-shadow: inset 6rpx 8rpx 16rpx rgba(47, 63, 58, 0.08);
  box-sizing: border-box;
}

.timer-input {
  width: 92rpx;
  height: 72rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
  color: #101c1a;
}

.timer-unit {
  margin-left: 6rpx;
  font-size: 22rpx;
  color: #6f817c;
}

.time-picker {
  font-size: 34rpx;
  font-weight: 900;
  color: #101c1a;
}

.timer-action,
.timer-cancel {
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 34rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.timer-action {
  width: 100%;
  margin-top: 20rpx;
  background: linear-gradient(145deg, #12c9aa, #087a68);
  color: #fff;
  box-shadow: 0 12rpx 22rpx rgba(12, 167, 140, 0.22);
}

.timer-cancel {
  width: 100%;
  margin-top: 18rpx;
  background: linear-gradient(145deg, #ffffff, #dbe4e1);
  color: #314944;
  box-shadow:
    8rpx 10rpx 20rpx rgba(37, 51, 47, 0.12),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.96);
}

.mode-grid,
.speed-grid {
  display: grid;
  gap: 14rpx;
}

.mode-grid {
  grid-template-columns: 1fr;
}

.speed-grid {
  grid-template-columns: repeat(5, 1fr);
}

.mode-chip,
.speed-btn {
  min-height: 94rpx;
  padding: 18rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #ffffff, #dfe8e5);
  color: #38564f;
  font-size: 23rpx;
  box-shadow:
    10rpx 12rpx 22rpx rgba(37, 51, 47, 0.12),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
}

.mode-chip.active,
.speed-btn.active {
  background: linear-gradient(145deg, #101c1a, #263833);
  color: #fff;
  font-weight: 900;
}

.speed-btn.disabled {
  background: linear-gradient(145deg, #9aa7a2, #687670);
  color: #25302d;
  box-shadow:
    inset 6rpx 8rpx 16rpx rgba(34, 46, 42, 0.2),
    5rpx 7rpx 12rpx rgba(38, 50, 46, 0.12);
}

.speed-btn.disabled.active {
  background: linear-gradient(145deg, #596761, #2f3c37);
  color: #e9efed;
}

.smart .section-head {
  margin-bottom: 12rpx;
}

.smart-desc,
.telemetry-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: #61736f;
}

.telemetry-text {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(236, 244, 241, 0.88);
  word-break: break-all;
  box-shadow: inset 6rpx 6rpx 14rpx rgba(48, 63, 59, 0.08);
}

.log-row {
  margin-top: 14rpx;
  display: flex;
  gap: 14rpx;
  font-size: 22rpx;
  color: #526760;
}

.log-time {
  width: 96rpx;
  flex-shrink: 0;
  color: #8a9b97;
}

.log-text {
  flex: 1;
  word-break: break-all;
}

.author-footer {
  margin-top: 12rpx;
  padding: 8rpx 0 4rpx;
  text-align: center;
}

.author-text {
  font-size: 22rpx;
  color: #73827e;
}
