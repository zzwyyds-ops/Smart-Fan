page {
  min-height: 100%;
  background: #eef2f0;
}

.home-page {
  min-height: 100vh;
  padding: 26rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 8% 10%, rgba(255, 112, 82, 0.18) 0, rgba(255, 112, 82, 0) 220rpx),
    radial-gradient(circle at 92% 8%, rgba(21, 211, 177, 0.16) 0, rgba(21, 211, 177, 0) 240rpx),
    linear-gradient(145deg, #f8faf8 0%, #e4ecea 56%, #d6ddda 100%);
}

.console-shell {
  min-height: 88vh;
  padding: 30rpx 24rpx;
  border-radius: 46rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(217, 225, 223, 0.9));
  box-shadow:
    24rpx 30rpx 62rpx rgba(30, 43, 39, 0.2),
    -14rpx -16rpx 36rpx rgba(255, 255, 255, 0.92),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
}

.topbar {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.top-copy {
  flex: 1;
  min-width: 0;
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  color: #798683;
}

.title {
  display: block;
  margin-top: 10rpx;
  font-size: 54rpx;
  line-height: 1.12;
  font-weight: 900;
  color: #101c1a;
}

.subtitle {
  display: block;
  margin-top: 14rpx;
  max-width: 420rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #667774;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: 10rpx 12rpx 20rpx rgba(35, 48, 44, 0.12);
}

.status-pill.online {
  background: linear-gradient(145deg, #e9fffa, #c8f4ea);
  color: #0d6f60;
}

.status-pill.offline {
  background: linear-gradient(145deg, #ffffff, #dee6e3);
  color: #5f726d;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: currentColor;
}

.hero-stage {
  position: relative;
  min-height: 700rpx;
  margin-top: 24rpx;
  border-radius: 42rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(215, 223, 220, 0.9)),
    linear-gradient(145deg, #f8fbfa, #d5dcda);
  box-shadow:
    22rpx 28rpx 58rpx rgba(28, 39, 36, 0.16),
    -14rpx -16rpx 36rpx rgba(255, 255, 255, 0.9),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.halo {
  position: absolute;
  border-radius: 50%;
  filter: blur(4rpx);
}

.halo-a {
  left: -40rpx;
  top: 90rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 112, 82, 0.18);
}

.halo-b {
  right: 40rpx;
  bottom: 120rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(21, 211, 177, 0.16);
}

.floating-card {
  position: absolute;
  z-index: 4;
  min-width: 180rpx;
  padding: 24rpx 22rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(229, 236, 234, 0.9));
  box-shadow:
    16rpx 18rpx 34rpx rgba(32, 45, 41, 0.16),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
}

.temp-card {
  left: 28rpx;
  top: 36rpx;
  background: linear-gradient(145deg, #fff7f3, #ffd7cb);
}

.humidity-card {
  right: 28rpx;
  top: 48rpx;
  background: linear-gradient(145deg, #effffb, #bfeee2);
}

.mode-card {
  left: 26rpx;
  bottom: 58rpx;
}

.timer-card {
  right: 24rpx;
  bottom: 74rpx;
  width: 220rpx;
}

.floating-label {
  display: block;
  font-size: 22rpx;
  color: #71807d;
}

.floating-value {
  display: block;
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 900;
  color: #101c1a;
}

.floating-unit {
  margin-left: 2rpx;
  font-size: 22rpx;
}

.floating-text {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #101c1a;
  line-height: 1.3;
}

.floating-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6a7b77;
}

.home-fan {
  position: absolute;
  left: 50%;
  bottom: 40rpx;
  width: 360rpx;
  height: 520rpx;
  transform: translateX(-50%);
}

.fan-shadow {
  position: absolute;
  left: 66rpx;
  right: 66rpx;
  bottom: 8rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(31, 42, 39, 0.16);
  box-shadow: 0 0 30rpx rgba(31, 42, 39, 0.08);
}

.fan-head {
  position: absolute;
  left: 30rpx;
  top: 0;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #fefefe, #cdd8d5);
  box-shadow:
    22rpx 24rpx 42rpx rgba(21, 31, 28, 0.24),
    inset -14rpx -14rpx 24rpx rgba(55, 70, 66, 0.12),
    inset 14rpx 12rpx 22rpx rgba(255, 255, 255, 0.94);
}

.fan-ring {
  position: absolute;
  border-radius: 50%;
}

.fan-ring.outer {
  inset: 18rpx;
  border: 12rpx solid rgba(25, 38, 35, 0.12);
}

.fan-ring.inner {
  inset: 34rpx;
  border: 4rpx solid rgba(17, 31, 28, 0.2);
}

.fan-cage {
  position: absolute;
  inset: 36rpx;
  border-radius: 50%;
  z-index: 7;
}

.cage-line {
  position: absolute;
  left: 50%;
  top: 6rpx;
  width: 3rpx;
  height: 218rpx;
  border-radius: 999rpx;
  background: rgba(23, 42, 38, 0.18);
  transform-origin: 50% 108rpx;
}

.line-1 {
  transform: translateX(-50%) rotate(0deg);
}

.line-2 {
  transform: translateX(-50%) rotate(45deg);
}

.line-3 {
  transform: translateX(-50%) rotate(90deg);
}

.line-4 {
  transform: translateX(-50%) rotate(135deg);
}

.fan-rotor {
  position: absolute;
  left: 71rpx;
  top: 71rpx;
  width: 158rpx;
  height: 158rpx;
  border-radius: 50%;
  z-index: 5;
  transform-origin: center center;
}

.fan-blade {
  position: absolute;
  left: 72rpx;
  top: 8rpx;
  width: 42rpx;
  height: 96rpx;
  border-radius: 42rpx 42rpx 18rpx 18rpx;
  background: linear-gradient(165deg, #15211f, #0aa389 72%, #a9fff0);
  box-shadow: 8rpx 10rpx 18rpx rgba(14, 28, 25, 0.2);
  transform-origin: 7rpx 72rpx;
}

.blade-1 {
  transform: rotate(0deg);
}

.blade-2 {
  transform: rotate(120deg);
}

.blade-3 {
  transform: rotate(240deg);
}

.fan-hub {
  position: absolute;
  left: 122rpx;
  top: 122rpx;
  width: 56rpx;
  height: 56rpx;
  z-index: 8;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #ffffff 0, #dfe8e5 35%, #162521 72%);
  box-shadow: 0 10rpx 16rpx rgba(13, 28, 25, 0.2);
}

.fan-neck {
  position: absolute;
  left: 164rpx;
  top: 286rpx;
  width: 30rpx;
  height: 92rpx;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #cdd8d5, #ffffff 45%, #aebab5);
  box-shadow: 10rpx 10rpx 20rpx rgba(22, 34, 31, 0.16);
}

.fan-stand {
  position: absolute;
  left: 176rpx;
  top: 364rpx;
  width: 8rpx;
  height: 70rpx;
  border-radius: 10rpx;
  background: #172420;
}

.fan-base {
  position: absolute;
  left: 58rpx;
  bottom: 26rpx;
  width: 244rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #fefefe, #b9c6c2);
  box-shadow:
    16rpx 18rpx 28rpx rgba(20, 31, 28, 0.18),
    inset 8rpx 10rpx 18rpx rgba(255, 255, 255, 0.9);
}

.base-indicator {
  position: absolute;
  left: 86rpx;
  top: 22rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #9aa9a5;
}

.base-indicator.on {
  background: #0ca78c;
  box-shadow: 0 0 24rpx rgba(12, 167, 140, 0.8);
}

.meta-panel {
  margin-top: 22rpx;
  padding: 24rpx 26rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(226, 233, 231, 0.92));
  box-shadow:
    16rpx 20rpx 38rpx rgba(35, 48, 44, 0.14),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.device-block {
  flex: 1;
  min-width: 0;
}

.device-name {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #101c1a;
}

.device-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6a7b77;
}

.meta-chip {
  min-width: 156rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #162622, #2d3e39);
  box-shadow: 0 14rpx 24rpx rgba(24, 39, 35, 0.18);
  box-sizing: border-box;
}

.meta-chip-label {
  display: block;
  font-size: 20rpx;
  color: rgba(242, 251, 248, 0.72);
}

.meta-chip-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #f2fbf8;
}

.speed-panel {
  margin-top: 20rpx;
  padding: 24rpx 26rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at right top, rgba(255, 112, 82, 0.18), rgba(255, 112, 82, 0) 180rpx),
    linear-gradient(145deg, rgba(18, 31, 28, 0.96), rgba(41, 61, 56, 0.94));
  box-shadow:
    18rpx 22rpx 44rpx rgba(20, 31, 28, 0.2),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.speed-panel-copy {
  flex: 1;
  min-width: 0;
}

.speed-panel-label {
  display: block;
  font-size: 22rpx;
  color: rgba(234, 244, 241, 0.72);
}

.speed-panel-value {
  display: block;
  margin-top: 10rpx;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 900;
  color: #ffffff;
}

.speed-panel-detail {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(234, 244, 241, 0.82);
}

.speed-panel-meter {
  width: 220rpx;
  flex-shrink: 0;
}

.speed-panel-meter-label {
  display: block;
  font-size: 20rpx;
  color: rgba(234, 244, 241, 0.68);
}

.speed-panel-track {
  margin-top: 14rpx;
  width: 100%;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  overflow: hidden;
}

.speed-panel-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #15d3b1, #ff9f6a);
  box-shadow: 0 0 20rpx rgba(21, 211, 177, 0.35);
}

.speed-panel-meter-text {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  font-weight: 800;
  text-align: right;
  color: #ffffff;
}

.action-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.action-card {
  min-height: 166rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(224, 232, 229, 0.9));
  box-shadow:
    16rpx 20rpx 40rpx rgba(35, 48, 44, 0.14),
    -8rpx -8rpx 22rpx rgba(255, 255, 255, 0.88),
    inset 1rpx 1rpx 0 rgba(255, 255, 255, 0.96);
}

.action-card:active {
  transform: scale(0.985);
}

.action-icon {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 12rpx 14rpx 28rpx rgba(35, 48, 44, 0.16);
}

.debug-icon {
  background: linear-gradient(145deg, #17221f, #344842);
}

.fan-icon {
  border-radius: 50%;
  background: linear-gradient(145deg, #ffffff, #cbd8d4);
}

.chip-line {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  height: 8rpx;
  border-radius: 10rpx;
  background: #13d3b1;
}

.line-a {
  top: 34rpx;
}

.line-b {
  top: 60rpx;
  background: #ff7052;
}

.chip-dot {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fff;
}

.dot-a {
  left: 24rpx;
  top: 32rpx;
}

.dot-b {
  right: 24rpx;
  top: 57rpx;
}

.mini-rotor {
  position: absolute;
  left: 25rpx;
  top: 25rpx;
  width: 54rpx;
  height: 54rpx;
}

.mini-blade {
  position: absolute;
  left: 24rpx;
  top: 0;
  width: 16rpx;
  height: 40rpx;
  border-radius: 18rpx;
  background: linear-gradient(165deg, #101c1a, #0ca78c);
  transform-origin: 4rpx 30rpx;
}

.blade-a {
  transform: rotate(0deg);
}

.blade-b {
  transform: rotate(120deg);
}

.blade-c {
  transform: rotate(240deg);
}

.mini-hub {
  position: absolute;
  left: 42rpx;
  top: 42rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #101c1a;
  box-shadow: 0 5rpx 10rpx rgba(17, 28, 26, 0.2);
}

.action-content {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.action-title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #101c1a;
}

.action-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6b7c83;
}

.home-fan-off,
.home-fan-speed-1,
.home-fan-speed-2,
.home-fan-speed-3,
.home-fan-speed-4,
.home-fan-speed-5 {
  transform-origin: center center;
}

.home-fan-off {
  animation: none;
}

.home-fan-speed-1 {
  animation: homeFanSpin 1.1s linear infinite;
}

.home-fan-speed-2 {
  animation: homeFanSpin 0.82s linear infinite;
}

.home-fan-speed-3 {
  animation: homeFanSpin 0.58s linear infinite;
}

.home-fan-speed-4 {
  animation: homeFanSpin 0.38s linear infinite;
}

.home-fan-speed-5 {
  animation: homeFanSpin 0.24s linear infinite;
}

@keyframes homeFanSpin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.footer {
  margin-top: 20rpx;
  text-align: center;
  font-size: 22rpx;
  color: #74817e;
}
