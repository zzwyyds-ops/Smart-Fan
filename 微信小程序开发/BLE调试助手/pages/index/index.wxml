<view class="debug-page">
  <view class="hero-panel">
    <view class="hero-top">
      <view>
        <text class="hero-title">调试入口</text>
        <text class="hero-subtitle">BLE 扫描、连接、收发字节与日志查看</text>
      </view>
      <view class="hero-status {{bleReady ? 'ready' : 'off'}}">
        <text class="hero-status-dot"></text>
        <text>{{bleReady ? '蓝牙已就绪' : '蓝牙未就绪'}}</text>
      </view>
    </view>

    <view class="hero-badges">
      <view class="hero-badge">
        <text class="badge-label">当前状态</text>
        <text class="badge-value">{{connected ? '已连接' : connecting ? '连接中' : scanning ? '扫描中' : '待连接'}}</text>
      </view>
      <view class="hero-badge">
        <text class="badge-label">数据模式</text>
        <text class="badge-value">{{sendMode === 'hex' ? 'HEX' : '文本'}}</text>
      </view>
      <view class="hero-badge">
        <text class="badge-label">接收展示</text>
        <text class="badge-value">{{hexDisplay ? 'HEX' : 'ASCII'}}</text>
      </view>
    </view>
  </view>

  <block wx:if="{{!connected && !connecting}}">
    <view class="section-card">
      <view class="section-head">
        <text class="section-title">设备扫描</text>
        <text class="section-hint">{{scanning ? '正在搜索附近设备' : '点击开始扫描'}}</text>
      </view>

      <button class="scan-btn {{scanning ? 'scanning' : ''}}" bindtap="toggleScan">
        <text wx:if="{{!scanning}}">开始扫描</text>
        <text wx:else>停止扫描</text>
      </button>

      <scroll-view class="device-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:if="{{devices.length === 0 && !scanning}}" class="empty-state">
          <text class="empty-icon">BLE</text>
          <text class="empty-text">未发现设备</text>
          <text class="empty-sub">请确保设备已上电并处于广播状态</text>
        </view>
        <view wx:if="{{devices.length === 0 && scanning}}" class="empty-state">
          <text class="empty-icon scanning-icon">BLE</text>
          <text class="empty-text">正在搜索...</text>
        </view>
        <view
          wx:for="{{devices}}"
          wx:key="deviceId"
          class="device-card"
          bindtap="connectDevice"
          data-device="{{item}}"
        >
          <view class="device-info">
            <text class="device-name">{{item.name || item.localName || '未知设备'}}</text>
            <text class="device-id">{{item.deviceId}}</text>
          </view>
          <view class="device-meta">
            <view class="signal-bars">
              <view class="signal-bar {{item.rssiLevel >= 1 ? 'on' : ''}}"></view>
              <view class="signal-bar {{item.rssiLevel >= 2 ? 'on' : ''}}"></view>
              <view class="signal-bar {{item.rssiLevel >= 3 ? 'on' : ''}}"></view>
              <view class="signal-bar {{item.rssiLevel >= 4 ? 'on' : ''}}"></view>
            </view>
            <text class="rssi-text">{{item.RSSI}} dBm</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </block>

  <block wx:elif="{{connecting}}">
    <view class="section-card center-card">
      <view class="connecting-spinner"></view>
      <text class="connecting-text">正在连接 {{deviceName}}...</text>
    </view>
  </block>

  <block wx:else>
    <view class="section-card connection-card">
      <view class="connection-row">
        <view class="conn-device">
          <text class="conn-name">{{deviceName}}</text>
          <text class="conn-status">● 已连接</text>
        </view>
        <button class="disconnect-btn" bindtap="disconnect">断开</button>
      </view>

      <view class="connection-mini-grid">
        <view class="mini-info">
          <text class="mini-label">写入</text>
          <text class="mini-value">{{writeCharId ? writeCharId.slice(4, 8).toUpperCase() : '--'}}</text>
        </view>
        <view class="mini-info">
          <text class="mini-label">通知</text>
          <text class="mini-value">{{notifyCharId ? notifyCharId.slice(4, 8).toUpperCase() : '--'}}</text>
        </view>
        <view class="mini-info">
          <text class="mini-label">连接模式</text>
          <text class="mini-value">{{writeType}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">接收日志</text>
        <view class="toolbar">
          <view class="tool-btn {{hexDisplay ? 'active' : ''}}" bindtap="toggleHexDisplay">
            <text>{{hexDisplay ? 'HEX' : 'ASCII'}}</text>
          </view>
          <view class="tool-btn" bindtap="clearData">
            <text>清除</text>
          </view>
        </view>
      </view>

      <scroll-view
        class="data-area"
        scroll-y
        enhanced
        show-scrollbar="{{true}}"
        scroll-into-view="{{scrollToId}}"
      >
        <view wx:if="{{receivedData.length === 0}}" class="data-empty">
          <text class="data-empty-text">等待接收数据...</text>
        </view>
        <view
          wx:for="{{receivedData}}"
          wx:key="index"
          class="data-item {{item.direction === 'send' ? 'sent' : 'received'}}"
          id="data-{{index}}"
        >
          <text class="data-time">{{item.time}}</text>
          <text class="data-direction">{{item.label}}</text>
          <text class="data-hex">{{item.raw || item.hex}}</text>
          <text wx:if="{{!hexDisplay}}" class="data-ascii">{{item.ascii}}</text>
        </view>
      </scroll-view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">发送控制</text>
        <text class="section-hint">{{sendMode === 'hex' ? 'HEX 字节发送' : '文本 UTF-8 发送'}}</text>
      </view>

      <view class="send-mode-row">
        <view class="mode-switch" bindtap="toggleSendMode">
          <text class="mode-option {{sendMode === 'text' ? 'active' : ''}}">文本</text>
          <text class="mode-option {{sendMode === 'hex' ? 'active' : ''}}">HEX</text>
        </view>
      </view>

      <view class="send-row">
        <input
          class="send-input"
          type="text"
          placeholder="{{sendMode === 'hex' ? '例：01 02 0D 0A' : '输入要发送的数据...'}}"
          value="{{sendText}}"
          bindinput="onSendInput"
          confirm-type="send"
          bindconfirm="sendData"
          maxlength="512"
        />
        <button class="send-btn" bindtap="sendData" disabled="{{!canSend}}">发送</button>
      </view>

      <view class="send-hint-wrap">
        <text class="send-hint">{{sendMode === 'hex' ? 'HEX 模式发送真实字节，例如 01 02 会发两个字节' : '文本模式按 UTF-8 发送，例如 123 会发 31 32 33'}}</text>
      </view>
    </view>
  </block>

  <view class="author-footer">
    <text class="author-text">作者：张志伟</text>
  </view>
</view>
