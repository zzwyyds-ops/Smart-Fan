page {
  min-height: 100%;
  background: #efefee;
}

.debug-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 8%, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0) 38%),
    linear-gradient(180deg, #f3f1ef 0%, #eeeeec 100%);
}

.hero-panel,
.section-card {
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 20rpx 46rpx rgba(54, 54, 54, 0.12);
  backdrop-filter: blur(10rpx);
}

.hero-panel {
  padding: 28rpx 28rpx 22rpx;
  margin-bottom: 18rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #161616;
}

.hero-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a7a7a;
}

.hero-status {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #2b2b2b;
  background: #f3f3f3;
}

.hero-status.ready {
  background: #e4f5e8;
  color: #216b37;
}

.hero-status.off {
  background: #f2ece7;
  color: #8b5d31;
}

.hero-status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.hero-badges {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.hero-badge {
  min-height: 112rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6f6f6 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.badge-label {
  display: block;
  font-size: 20rpx;
  color: #8c8c8c;
}

.badge-value {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #151515;
}

.section-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #161616;
}

.section-hint {
  font-size: 22rpx;
  color: #8a8a8a;
}

.scan-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #19bc57 0%, #0ea94a 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 28rpx rgba(17, 167, 75, 0.26);
  border: none;
}

.scan-btn::after,
.send-btn::after,
.disconnect-btn::after {
  border: none;
}

.scan-btn.scanning {
  background: linear-gradient(135deg, #ff7f60 0%, #f05d42 100%);
  box-shadow: 0 14rpx 28rpx rgba(240, 93, 66, 0.24);
}

.device-list {
  margin-top: 18rpx;
  max-height: 58vh;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  min-height: 320rpx;
  padding: 20rpx 8rpx;
}

.empty-icon,
.scanning-icon {
  font-size: 78rpx;
  font-weight: 800;
  color: #c8c8c8;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
}

.empty-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8b8b8b;
}

.device-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 18rpx;
  margin-bottom: 14rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #ececec;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.05);
}

.device-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.device-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #161616;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.device-id {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #9a9a9a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.device-meta {
  flex-shrink: 0;
  margin-left: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.signal-bars {
  display: flex;
  align-items: flex-end;
  gap: 5rpx;
  height: 28rpx;
}

.signal-bar {
  width: 6rpx;
  border-radius: 999rpx;
  background: #dadada;
}

.signal-bar:nth-child(1) { height: 8rpx; }
.signal-bar:nth-child(2) { height: 14rpx; }
.signal-bar:nth-child(3) { height: 20rpx; }
.signal-bar:nth-child(4) { height: 26rpx; }

.signal-bar.on {
  background: linear-gradient(180deg, #19bc57 0%, #0ea94a 100%);
}

.rssi-text {
  font-size: 20rpx;
  color: #7f7f7f;
}

.center-card {
  min-height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.connecting-spinner {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 8rpx solid #ececec;
  border-top-color: #19bc57;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.connecting-text {
  font-size: 28rpx;
  color: #4b4b4b;
}

.connection-card {
  padding-bottom: 20rpx;
}

.connection-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.conn-device {
  flex: 1;
  min-width: 0;
}

.conn-name {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #111;
}

.conn-status {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8d8d8d;
}

.disconnect-btn {
  margin-right: -8rpx;
  min-width: 126rpx;
  height: 62rpx;
  line-height: 62rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #19bc57;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.connection-mini-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.mini-info {
  padding: 14rpx 12rpx;
  border-radius: 18rpx;
  background: #f7f7f7;
  border: 1rpx solid #ededed;
}

.mini-label {
  display: block;
  font-size: 19rpx;
  color: #8c8c8c;
}

.mini-value {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #151515;
}

.toolbar {
  display: flex;
  gap: 10rpx;
}

.tool-btn {
  min-width: 92rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e7e7e7;
  background: #f7f7f7;
  color: #444;
  font-size: 20rpx;
}

.tool-btn.active {
  background: #222;
  border-color: #222;
  color: #fff;
}

.data-area {
  max-height: 46vh;
}

.data-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 220rpx;
}

.data-empty-text {
  font-size: 24rpx;
  color: #b0b0b0;
}

.data-item {
  padding: 16rpx 16rpx;
  margin-bottom: 10rpx;
  border-radius: 18rpx;
  background: #f8f8f8;
  border: 1rpx solid #ececec;
}

.data-item.received {
  background: #f5fbf7;
  border-left: 6rpx solid #19bc57;
}

.data-item.sent {
  background: #f7f6fb;
  border-left: 6rpx solid #6f65ff;
}

.data-time {
  display: block;
  font-size: 19rpx;
  color: #9a9a9a;
}

.data-direction {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #171717;
}

.data-hex {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #292929;
  word-break: break-all;
}

.data-ascii {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #777;
  word-break: break-all;
}

.send-mode-row {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 14rpx;
}

.mode-switch {
  display: flex;
  padding: 4rpx;
  border-radius: 999rpx;
  background: #efefef;
}

.mode-option {
  min-width: 88rpx;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #6f6f6f;
}

.mode-option.active {
  background: #19bc57;
  color: #fff;
  font-weight: 700;
}

.send-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.send-input {
  flex: 1;
  height: 84rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f7f7f7;
  border: 1rpx solid #e8e8e8;
  font-size: 26rpx;
  color: #161616;
}

.send-btn {
  width: 132rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: #19bc57;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 20rpx rgba(25, 188, 87, 0.18);
}

.send-btn[disabled] {
  background: #c6d3ca;
  color: #6d7a70;
  box-shadow: none;
}

.send-hint-wrap {
  margin-top: 10rpx;
}

.send-hint {
  font-size: 20rpx;
  color: #9a9a9a;
}

.author-footer {
  padding: 10rpx 0 6rpx;
  text-align: center;
}

.author-text {
  font-size: 22rpx;
  color: #8f8f8f;
}
